{
  "name": "@mcpforge/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ts-morph": "latest",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "tsup": "latest",
    "@types/node": "latest"
  }
}
